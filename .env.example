# Copy to .env and fill in real values. The app runs with only these two vars.

# PostgreSQL connection string (Neon, Supabase, or local Postgres).
# Example (Neon): postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Auth.js session/JWT secret. Generate one with: npx auth secret  (or: openssl rand -base64 32)
AUTH_SECRET="replace-with-a-long-random-string"
