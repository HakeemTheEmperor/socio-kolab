// Club Portal — Prisma schema (see SPEC.md §4)
// Prisma 7 "prisma-client" generator: client is emitted to src/generated/prisma
// and imported via "@/generated/prisma/client".

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // Prisma 7: connection URL lives in prisma.config.ts (CLI) and is passed to
  // PrismaClient via a driver adapter at runtime (see src/lib/prisma.ts).
}

enum ClubStatus {
  PENDING // requested, awaiting platform admin approval
  ACTIVE
  REJECTED
  SUSPENDED // reversible off-switch for a club (admin only)
}

model Club {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique // human-readable URL segment: /{slug}/dashboard
  status      ClubStatus @default(PENDING)
  description String?
  logoUrl     String?
  settings    Json       @default("{}")
  // settings shape: { duesAmount: number, currency: string ("NGN"),
  //                   currentPeriod: string (e.g. "2026/2027"),
  //                   departments: string[], committees: string[],
  //                   membershipOpen: boolean }

  // Lifecycle: who asked for this club, and when an admin approved it.
  requestedById String? // User.id of the creator (no FK: purely informational)
  approvedAt    DateTime?

  memberships Membership[]
  events      Event[]
  dues        DuesRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model User {
  id                 String  @id @default(cuid())
  email              String  @unique
  name               String
  passwordHash       String
  mustChangePassword Boolean @default(false)
  isPlatformAdmin    Boolean @default(false)

  // Email verification (SIGNUP.MD §1). `emailVerified` is a DateTime, not a
  // boolean — it records *when*, matches the Auth.js convention, and null reads
  // as "never verified" (the hard gate blocks login while it is null).
  emailVerified DateTime?

  // One live verification token per user, stored inline (SIGNUP.MD §1.2). The
  // email carries the raw token; the DB stores only sha256(raw), so a leaked row
  // cannot verify an account. Issuing a new token overwrites these columns,
  // which *is* the invalidation of any previous link. All three move together:
  // set on issue, null on consume.
  verificationTokenHash   String?   @unique
  verificationTokenSentAt DateTime?
  verificationTokenExpiry DateTime?

  // Password reset — a parallel, never-shared token slot (SIGNUP.MD §1.2, §9),
  // so a verification resend can't kill a pending reset link or vice versa.
  resetTokenHash   String?   @unique
  resetTokenSentAt DateTime?
  resetTokenExpiry DateTime?

  memberships Membership[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  PRESIDENT
  EXEC
  MEMBER
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  ALUMNI
  PENDING // registered, awaiting exec approval
}

model Membership {
  id         String       @id @default(cuid())
  club       Club         @relation(fields: [clubId], references: [id])
  clubId     String
  user       User         @relation(fields: [userId], references: [id])
  userId     String
  role       Role         @default(MEMBER)
  status     MemberStatus @default(PENDING)
  department String?
  level      String? // academic year/level, e.g. "300"
  committee  String?
  phone      String?
  joinedAt   DateTime     @default(now())
  dues       DuesRecord[]
  attendance Attendance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clubId, userId])
  @@index([clubId, status])
}

model DuesRecord {
  id           String     @id @default(cuid())
  club         Club       @relation(fields: [clubId], references: [id])
  clubId       String
  membership   Membership @relation(fields: [membershipId], references: [id])
  membershipId String
  period       String // e.g. "2026/2027"
  amount       Decimal    @db.Decimal(10, 2)
  paidAt       DateTime   @default(now())
  method       String? // "cash" | "transfer" | "other"
  recordedById String // membership id of the exec who recorded it
  note         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([membershipId, period])
  @@index([clubId, period])
}

enum RsvpStatus {
  GOING
  NOT_GOING
  MAYBE
}

model Event {
  id          String   @id @default(cuid())
  club        Club     @relation(fields: [clubId], references: [id])
  clubId      String
  title       String
  description String?
  location    String?
  startsAt    DateTime
  endsAt      DateTime?
  attendance  Attendance[]

  // Custom registration form (EVENT-FORMS.md §1.1). `formSchema` is an ordered
  // array of field definitions keyed by an immutable client-generated id; see
  // src/lib/event-forms.ts for its shape and validation. Stored as JSONB — one
  // atomic unit, never queried field-by-field (rationale in DECISIONS.md).
  formSchema         Json    @default("[]")
  acceptingResponses Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clubId, startsAt])
}

model Attendance {
  id            String       @id @default(cuid())
  event         Event        @relation(fields: [eventId], references: [id])
  eventId       String
  // Optional now: a registration is EITHER a member (membershipId) OR a guest
  // (guestName + guestEmail), never both, never neither. Prisma can't express
  // that XOR, so it is enforced in the submit server action (EVENT-FORMS.md §1.2).
  membership    Membership?  @relation(fields: [membershipId], references: [id])
  membershipId  String?
  guestName     String?
  guestEmail    String? // stored lowercased/trimmed
  formResponses Json         @default("{}") // { [fieldId]: string | number | boolean }
  rsvp          RsvpStatus?
  checkedInAt   DateTime?
  checkedInById String? // membership id of exec who checked them in

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Postgres treats NULLs as distinct, so these dedup members and guests
  // independently: one member row per event, one guest row per event+email.
  @@unique([eventId, membershipId])
  @@unique([eventId, guestEmail])
}
