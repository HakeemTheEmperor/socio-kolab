# Copy to .env and fill in real values.
#
# Locally you only need the two variables in "Required". Everything below that
# is optional in development — the app degrades to a safe local behaviour — but
# should be set in production. Each section says what happens if you skip it.


# ─────────────────────────────────────────────────────────────────────────────
# Required (everywhere)
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string, used by the app at runtime.
# Local / Neon / any single-URL Postgres: use it as-is, and leave IS_SUPABASE
# unset. On Supabase this must be the POOLED string — see "Supabase" below.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Auth.js session/JWT secret.
# Generate with:  npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="replace-with-a-long-random-string"


# ─────────────────────────────────────────────────────────────────────────────
# Email — verification + password reset
# Unset locally → links are logged to the server console instead of sent.
# ─────────────────────────────────────────────────────────────────────────────

# Public origin used to build absolute links in emails.
# Falls back to http://localhost:3000, so console-mode links stay clickable.
# Set this in every deployed environment.
APP_URL="http://localhost:3000"

# Unset → console mode (dev and CI never need a mail provider).
# RESEND_API_KEY=""

# Sender address; its domain must be verified in Resend (SPF/DKIM).
# EMAIL_FROM="Club Portal <noreply@yourdomain>"


# ─────────────────────────────────────────────────────────────────────────────
# Session revocation — Upstash Redis
# Both unset → the check is a no-op and revocation is simply disabled.
# ─────────────────────────────────────────────────────────────────────────────

# JWT sessions are revocable via a Redis allowlist: logout, "log out on password
# reset", one-session-per-user. Set both to enable it.

# UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="..."


# ─────────────────────────────────────────────────────────────────────────────
# Supabase only — leave this whole section out for local development
# ─────────────────────────────────────────────────────────────────────────────

# Supabase needs two connection strings, because the app and the Prisma CLI want
# opposite things. IS_SUPABASE=true switches the CLI over to DIRECT_URL; unset
# (the local default), the CLI uses DATABASE_URL like everything else.

# IS_SUPABASE="true"

# DATABASE_URL (above) is then the pooled URL the deployed app connects through:
#   - Serverless (Vercel, Netlify):        Transaction pooler, port 6543.
#   - Long-lived server (Fly, Railway, VPS): Session pooler, port 5432.
# Supabase's *direct* connection is IPv6-only unless you buy the IPv4 add-on, so
# it generally cannot be reached from Vercel at all.

# DIRECT_URL is where migrations and seeds run. They take advisory locks and run
# DDL, so they need a real session: use the Direct connection, or the Session
# pooler. Never port 6543 — migrations hang there rather than failing cleanly.

# DIRECT_URL="postgresql://postgres:password@db.xxx.supabase.co:5432/postgres?sslmode=require"


# ─────────────────────────────────────────────────────────────────────────────
# One-off: production seed (npm run db:seed:prod)
# Only needed for the single run that creates the club + president account.
# Pass these inline rather than committing them to .env.
# ─────────────────────────────────────────────────────────────────────────────

# SEED_PRESIDENT_NAME="Full Name"
# SEED_PRESIDENT_EMAIL="you@example.com"
# SEED_PASSWORD="choose-a-strong-one"   # omitted → a random one is printed once
